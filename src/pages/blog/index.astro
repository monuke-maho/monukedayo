---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { IconChevronLeft, IconTags } from "@tabler/icons-preact";
import { BLOG, UI } from "@/consts";
import BlogPostCard from "../../components/BlogPostCard.astro";

const allPosts = await getCollection(
  "blog",
  ({ data }) => import.meta.env.DEV || data.published,
);

const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout>
  <section class="flex w-full flex-col gap-6 py-16 md:py-24">
    <a
      href="/"
      class="flex w-fit flex-row items-center gap-2 text-sm font-medium text-slate-500 transition-colors hover:text-slate-900"
    >
      <IconChevronLeft size={16} /> {UI.backToHome}
    </a>
    <h1 class="text-4xl leading-tight font-bold text-slate-900 md:text-5xl tracking-tight">{BLOG.indexTitle}</h1>
    <p class="text-xl font-bold text-slate-500">
      {BLOG.indexDescription}
    </p>
  </section>

  <section class="flex flex-col gap-8 border-t border-slate-100 py-12">
    <div class="flex flex-row items-center justify-between">
      <div class="flex flex-row items-center gap-4">
        <h2 class="text-2xl font-bold">全ての投稿</h2>
        <a
          href="/tags"
          class="flex flex-row items-center gap-1 rounded-full bg-slate-100 px-3 py-1 text-xs font-bold text-slate-500 transition-colors hover:bg-emerald-50 hover:text-emerald-700"
        >
          <IconTags size={12} />
          Tags
        </a>
      </div>
      <p class="text-sm text-slate-500">{sortedPosts.length} 記事</p>
    </div>
    <div class="grid w-full grid-cols-1 gap-4">
      {sortedPosts.map((post) => <BlogPostCard post={post} />)}
    </div>
  </section>
</Layout>
