---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { ChevronLeft } from "@lucide/astro";
import BlogPostCard from "../../components/BlogPostCard.astro";

const allPosts = await getCollection(
  "blog",
  ({ data }) => import.meta.env.DEV || data.published,
);

const sortedPosts = allPosts.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Layout>
  <section class="flex w-full flex-col gap-6 py-16 md:py-24">
    <a
      href="/"
      class="flex w-fit flex-row items-center gap-2 text-sm font-medium text-slate-500 transition-colors hover:text-slate-900"
    >
      <ChevronLeft class="h-4 w-4" /> Home
    </a>
    <h1 class="text-6xl font-bold">Blog</h1>
    <p class="text-xl font-medium text-slate-500">
      日々の制作や考えたことの記録。
    </p>
  </section>

  <section class="flex flex-col gap-8 border-t border-slate-100 py-12">
    <div class="flex flex-row items-center justify-between">
      <h2 class="text-2xl font-bold">全ての投稿</h2>
      <p class="text-sm text-slate-500">{sortedPosts.length} 記事</p>
    </div>
    <div class="grid w-full grid-cols-1 gap-4">
      {sortedPosts.map((post) => <BlogPostCard post={post} />)}
    </div>
  </section>
</Layout>
