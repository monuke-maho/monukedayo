---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { IconChevronLeft, IconChevronRight } from "@tabler/icons-preact";
import TableOfContents from "../../components/TableOfContents.astro";
import BlogPostCard from "../../components/BlogPostCard.astro";
import { UI, BLOG } from "../../consts";

export async function getStaticPaths() {
  const posts = await getCollection(
    "blog",
    ({ data }) => import.meta.env.DEV || data.published,
  );
  const sortedPosts = posts.sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );

  return sortedPosts.map((post, i) => ({
    params: { id: post.id },
    props: {
      post,
      prevPost: i < sortedPosts.length - 1 ? sortedPosts[i + 1] : null,
      nextPost: i > 0 ? sortedPosts[i - 1] : null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);

// Find related posts by common tags
const allPosts = await getCollection(
  "blog",
  ({ data }) => import.meta.env.DEV || data.published,
);
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id)
  .filter((p) => p.data.tags?.some((tag) => post.data.tags?.includes(tag)))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Layout>
  <section class="flex w-full flex-col gap-8 py-16 md:py-24">
    <a
      href="/blog"
      class="flex w-fit flex-row items-center gap-2 text-sm font-medium text-slate-500 transition-colors hover:text-slate-900"
    >
      <IconChevronLeft size={16} />
      {UI.backToBlog}
    </a>

    <div class="flex flex-col gap-6">
      <div class="flex flex-row items-center gap-4">
        <div
          class="flex h-16 w-16 items-center justify-center rounded-2xl bg-emerald-50 text-3xl"
        >
          {post.data.emoji}
        </div>
        <div class="flex flex-col gap-1">
          <p class="text-sm font-medium text-slate-500">
            {
              post.data.date.toLocaleDateString("ja-jp", {
                year: "numeric",
                month: "2-digit",
                day: "2-digit",
              })
            }
          </p>
          {
            post.data.tags && post.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {post.data.tags.map((tag) => (
                  <a
                    href={`/tags/${tag}`}
                    class="text-xs text-slate-500 transition-all duration-300 hover:font-medium hover:text-slate-700"
                  >
                    #{tag}
                  </a>
                ))}
              </div>
            )
          }
        </div>
      </div>
      <h1
        class="text-4xl leading-tight font-bold tracking-tight text-slate-900 md:text-5xl"
      >
        {post.data.title}
      </h1>
      {
        post.data.description && (
          <p class="text-lg font-bold text-slate-500">
            {post.data.description}
          </p>
        )
      }
    </div>
  </section>

  <section class="border-t border-slate-100 py-12">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_300px]">
      <div class="flex flex-col gap-12">
        <div class="flex flex-col gap-10">
          {
            headings.length > 0 && (
              <div class="lg:hidden">
                <TableOfContents {headings} />
              </div>
            )
          }
          <article
            class="prose prose-slate prose-headings:font-bold prose-headings:text-slate-900 prose-a:font-bold prose-a:text-emerald-700 hover:prose-a:text-emerald-500 prose-img:rounded-2xl prose-code:after:hidden prose-code:before:hidden max-w-3xl"
          >
            <Content />
          </article>
        </div>

        <!-- Post Navigation -->
        <nav
          class="flex flex-row items-center justify-between gap-4 border-y border-slate-100 py-10"
        >
          {
            prevPost ? (
              <a
                href={`/blog/${prevPost.id}`}
                class="group flex flex-1 flex-col gap-2 text-left"
              >
                <span class="flex flex-row items-center gap-1 text-xs font-bold text-slate-400 transition-colors group-hover:text-emerald-600">
                  <IconChevronLeft size={12} /> {UI.previous}
                </span>
                <span class="line-clamp-1 text-sm font-bold text-slate-700 transition-colors group-hover:text-emerald-700">
                  {prevPost.data.title}
                </span>
              </a>
            ) : (
              <div class="flex-1" />
            )
          }

          <div class="h-8 w-px bg-slate-100"></div>

          {
            nextPost ? (
              <a
                href={`/blog/${nextPost.id}`}
                class="group flex flex-1 flex-col gap-2 text-right"
              >
                <span class="flex flex-row items-center justify-end gap-1 text-xs font-bold text-slate-400 transition-colors group-hover:text-emerald-600">
                  {UI.next} <IconChevronRight size={12} />
                </span>
                <span class="line-clamp-1 text-sm font-bold text-slate-700 transition-colors group-hover:text-emerald-700">
                  {nextPost.data.title}
                </span>
              </a>
            ) : (
              <div class="flex-1" />
            )
          }
        </nav>

        <!-- Related Posts -->
        {
          relatedPosts.length > 0 && (
            <div class="flex flex-col gap-8">
              <h2 class="text-2xl font-bold">{UI.relatedPosts}</h2>
              <div class="grid grid-cols-1 gap-4">
                {relatedPosts.map((p) => (
                  <BlogPostCard post={p} />
                ))}
              </div>
            </div>
          )
        }
      </div>

      {
        headings.length > 0 && (
          <aside class="hidden lg:block">
            <div class="sticky top-24">
              <TableOfContents {headings} />
            </div>
          </aside>
        )
      }
    </div>
  </section>
</Layout>
