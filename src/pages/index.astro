---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { IconChevronRight, IconFile, IconChevronLeft } from "@tabler/icons-preact";
import BlogPostCard from "../components/BlogPostCard.astro";
import { Image } from "astro:assets";
import iconImage from "../assets/icon.webp";
import { PROFILE, SOCIAL_LINKS, BLOG, UI } from "@/consts";

const allPosts = await getCollection(
  "blog",
  ({ data }) => import.meta.env.DEV || data.published,
);

const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);
---

<Layout>
  <section class="flex w-full flex-col gap-10 py-16 md:py-24">
    <div
      class="flex flex-col items-center gap-10 text-center md:flex-row md:items-center md:text-left"
    >
      <Image
        src={iconImage}
        alt={`${PROFILE.name}のアイコン`}
        class="h-40 w-40 rounded-3xl border-4 border-white object-cover shadow-lg transition-all duration-500 hover:rotate-3 hover:scale-105"
      />
      <div class="flex flex-1 flex-col gap-6">
        <div class="space-y-4">
          <h1
            class="text-6xl font-bold tracking-tight text-slate-900 md:text-7xl"
          >
            {PROFILE.name}
          </h1>
          <p
            class="text-xl font-bold leading-relaxed text-slate-500 md:text-2xl"
          >
            {PROFILE.bio}
          </p>
        </div>

        <div
          class="flex flex-wrap items-center justify-center gap-4 md:justify-start"
        >
          <div class="flex gap-3">
            {
              SOCIAL_LINKS.map((link) => (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class:list={[
                    "flex h-10 w-10 items-center justify-center rounded-2xl transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md",
                    link.platform === "GitHub"
                      ? "bg-slate-900 text-white hover:bg-emerald-600 hover:shadow-emerald-200"
                      : "bg-white text-slate-600 border border-slate-100 hover:bg-emerald-50 hover:text-emerald-600 hover:shadow-emerald-100",
                  ]}
                  aria-label={link.label}
                >
                  <link.icon size={20} />
                </a>
              ))
            }
          </div>

          <div class="h-6 w-px bg-slate-200 hidden md:block"></div>

          <div class="flex items-center gap-3">
            <a
              href="/blog"
              class="flex items-center gap-2 rounded-2xl bg-emerald-50 px-6 py-2.5 font-bold text-emerald-700 transition-all duration-300 hover:-translate-y-0.5 hover:bg-emerald-100 hover:shadow-md hover:shadow-emerald-100/30"
            >
              <IconFile size={18} />
              {BLOG.indexTitle}
            </a>
            <a
              href="/about"
              class="rounded-2xl bg-white border border-slate-100 px-6 py-2.5 font-bold text-slate-600 transition-all duration-300 hover:-translate-y-0.5 hover:bg-slate-50 hover:shadow-sm"
            >
              About
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="flex flex-col gap-8 border-t border-slate-100 py-12">
    <div class="flex flex-row items-center justify-between">
      <h2 class="text-2xl font-bold">{BLOG.recentPostsTitle}</h2>
      <a
        href="/blog"
        class="group flex flex-row items-center gap-2 *:transition-all *:duration-200"
      >
        {BLOG.allPostsButton}
        <IconChevronRight
          size={16}
          class="transition-transform group-hover:translate-x-1"
        />
      </a>
    </div>
    <div class="grid w-full grid-cols-1 gap-4">
      {recentPosts.map((post) => <BlogPostCard post={post} />)}
    </div>
  </section>
</Layout>
