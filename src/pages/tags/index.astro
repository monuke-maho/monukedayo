---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { IconChevronLeft, IconTags, IconHash } from "@tabler/icons-preact";
import TagBadge from "@/components/TagBadge.astro";
import { TAGS, UI } from "@/consts";

const allPosts = await getCollection(
  "blog",
  ({ data }) => import.meta.env.DEV || data.published,
);

const tagCounts = allPosts.reduce((acc, post) => {
  post.data.tags?.forEach((tag) => {
    acc[tag] = (acc[tag] || 0) + 1;
  });
  return acc;
}, {} as Record<string, number>);

const sortedTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
---

<Layout>
  <section class="flex w-full flex-col gap-6 py-16 md:py-24">
    <a
      href="/blog"
      class="flex w-fit flex-row items-center gap-2 text-sm font-medium text-slate-500 transition-colors hover:text-slate-900"
    >
      <IconChevronLeft size={16} /> {UI.backToBlog}
    </a>
    <div class="flex flex-row items-center gap-4">
      <div
        class="flex h-12 w-12 items-center justify-center rounded-2xl bg-slate-900 text-white shadow-lg shadow-slate-200"
      >
        <IconTags size={24} />
      </div>
      <h1 class="text-6xl font-bold tracking-tight text-slate-900">{TAGS.indexTitle}</h1>
    </div>
    <p class="text-xl font-bold text-slate-500">
      {TAGS.indexDescription}
    </p>
  </section>

  <section class="flex flex-col gap-8 border-t border-slate-100 py-12">
    <div class="flex flex-row items-center justify-between">
      <h2 class="text-2xl font-bold">全てのタグ</h2>
      <p class="text-sm text-slate-500">{sortedTags.length} 個のタグ</p>
    </div>
    <div class="flex flex-wrap gap-4">
      {sortedTags.map(([tag, count]) => <TagBadge tag={tag} count={count} />)}
      {sortedTags.length === 0 && (
        <p class="text-slate-500">タグがありません。</p>
      )}
    </div>
  </section>
</Layout>
