---
import { SITE, NAV_LINKS, SOCIAL_LINKS, UI } from "@/consts";

const today = new Date();
---

<footer class="mt-auto border-t border-slate-100 bg-white py-12 lg:py-16">
  <div class="mx-auto flex max-w-7xl flex-col gap-12 px-4 md:px-8">
    <div class="flex flex-col justify-between gap-12 md:flex-row">
      <div class="flex flex-col gap-4">
        <a
          href="/"
          class="text-xl font-bold transition-all hover:text-emerald-700"
          >{SITE.title}</a
        >
        <p class="max-w-xs text-sm leading-relaxed text-slate-500">
          {SITE.description}
        </p>
      </div>

      <div class="grid grid-cols-2 gap-12 md:gap-24">
        <div class="flex flex-col gap-4">
          <h3 class="text-sm font-bold tracking-wider text-slate-900 uppercase">
            Pages
          </h3>
          <nav class="flex flex-col gap-2 text-sm font-medium text-slate-500">
            {
              NAV_LINKS.map((link) => (
                <a
                  href={link.href}
                  class="transition-colors hover:text-emerald-700"
                >
                  {link.label}
                </a>
              ))
            }
          </nav>
        </div>

        <div class="flex flex-col gap-4">
          <h3 class="text-sm font-bold tracking-wider text-slate-900 uppercase">
            Social
          </h3>
          <div class="flex flex-row items-center gap-4 text-slate-500">
            {
              SOCIAL_LINKS.map((link) => (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="rounded-xl bg-slate-50 p-2 transition-all hover:bg-emerald-50 hover:text-emerald-700"
                  aria-label={link.label}
                >
                  <link.icon size={20} />
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <div
      class="flex flex-col items-center justify-between gap-4 border-t border-slate-50 pt-8 text-center md:flex-row md:text-left"
    >
      <p class="text-xs font-medium text-slate-400">
        {UI.copyright(today.getFullYear())}
      </p>
      <p class="text-xs font-medium text-slate-400">
        {UI.builtWith}
      </p>
    </div>
  </div>
</footer>
