---
import { List } from "@lucide/astro";

interface Props {
  headings: {
    depth: number;
    slug: string;
    text: string;
  }[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth > 1 && h.depth <= 3);
---

{
  filteredHeadings.length > 0 && (
    <nav class="flex flex-col gap-4 rounded-2xl bg-slate-50/50 p-6">
      <div class="flex flex-row items-center gap-2 font-bold text-slate-900">
        <List class="h-4 w-4 text-emerald-600" />
        目次
      </div>
      <ul class="flex flex-col gap-2 border-l border-slate-200 pl-4">
        {filteredHeadings.map((heading) => (
          <li
            class:list={[
              "text-sm transition-all duration-300",
              heading.depth === 2
                ? "font-medium text-slate-700"
                : "pl-4 text-slate-500",
            ]}
          >
            <a
              href={`#${heading.slug}`}
              class="toc-link block py-1 transition-all duration-300 hover:text-emerald-700"
              data-slug={heading.slug}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<script>
  const observeHeadings = () => {
    const observerOptions = {
      root: null,
      rootMargin: "-100px 0px -70% 0px",
      threshold: 0,
    };

    const tocLinks = document.querySelectorAll(".toc-link");
    const headings = Array.from(tocLinks)
      .map((link) => {
        const slug = link.getAttribute("data-slug");
        return slug ? document.getElementById(slug) : null;
      })
      .filter((h): h is HTMLElement => h !== null);

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          tocLinks.forEach((link) => {
            const slug = link.getAttribute("data-slug");
            if (slug === id) {
              link.classList.add("text-emerald-600", "font-bold", "translate-x-1");
            } else {
              link.classList.remove(
                "text-emerald-600",
                "font-bold",
                "translate-x-1",
              );
            }
          });
        }
      });
    }, observerOptions);

    headings.forEach((heading) => observer.observe(heading));
  };

  // Initialize
  observeHeadings();
  // Support for View Transitions
  document.addEventListener("astro:after-swap", observeHeadings);
</script>

<style>
  ul {
    list-style: none;
    margin: 0;
    padding-left: 0;
  }
</style>
