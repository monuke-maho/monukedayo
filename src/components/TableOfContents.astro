---
import { IconList } from "@tabler/icons-preact";
import { UI } from "@/consts";

interface Props {
  headings: {
    depth: number;
    slug: string;
    text: string;
  }[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth > 1 && h.depth <= 3);
---

{
  filteredHeadings.length > 0 && (
    <nav class="flex flex-col gap-4 rounded-3xl bg-white p-6 shadow-sm border border-slate-100">
      <div class="flex flex-row items-center gap-2 font-bold text-slate-900">
        <IconList size={16} class="text-emerald-600" />
        {UI.toc}
      </div>
      <ul class="flex flex-col gap-2 pl-4">
        {filteredHeadings.map((heading) => (
          <li
            class:list={[
              "text-sm transition-all duration-300",
              heading.depth === 2
                ? "font-medium text-slate-700"
                : "pl-4 text-slate-500",
            ]}
          >
            <a
              href={`#${heading.slug}`}
              class="toc-link block py-1 transition-all duration-300 hover:text-emerald-700"
              data-slug={heading.slug}
            >
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<script>
  const observeHeadings = () => {
    const observerOptions = {
      root: null,
      rootMargin: "-100px 0px -60% 0px",
      threshold: 0,
    };

    const tocLinks = document.querySelectorAll(".toc-link");
    const highlightClasses = ["text-emerald-600", "font-bold", "translate-x-1"];
    
    const clearHighlights = () => {
      tocLinks.forEach((link) => link.classList.remove(...highlightClasses));
    };

    const observer = new IntersectionObserver((entries) => {
      // If at the top of the page, don't highlight anything
      if (window.scrollY < 50) {
        clearHighlights();
        return;
      }

      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          tocLinks.forEach((link) => {
            const slug = link.getAttribute("data-slug");
            if (slug === id) {
              link.classList.add(...highlightClasses);
            } else {
              link.classList.remove(...highlightClasses);
            }
          });
        }
      });
    }, observerOptions);

    const headings = Array.from(tocLinks)
      .map((link) => {
        const slug = link.getAttribute("data-slug");
        return slug ? document.getElementById(slug) : null;
      })
      .filter((h): h is HTMLElement => h !== null);

    headings.forEach((heading) => observer.observe(heading));

    // Handle initial state and scroll to top
    window.addEventListener("scroll", () => {
      if (window.scrollY < 50) {
        clearHighlights();
      }
    }, { passive: true });
  };

  // Initialize
  observeHeadings();
  // Support for View Transitions
  document.addEventListener("astro:after-swap", observeHeadings);
</script>

<style>
  ul {
    list-style: none;
    margin: 0;
    padding-left: 0;
  }
</style>
