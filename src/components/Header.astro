---
import { SITE, NAV_LINKS } from "@/consts";
---

<header class="fixed top-4 z-50 h-16 w-full px-4 md:px-8">
  <div
    class="container mx-auto flex h-full w-full max-w-7xl flex-row items-center justify-between rounded-3xl border border-white/20 bg-white/70 px-6 py-4 shadow-md backdrop-blur-xl"
  >
    <a
      href="/"
      class="text-lg font-bold transition-colors hover:text-emerald-700"
      >{SITE.title}</a
    >
    <div>
      <nav
        class="flex flex-row items-center gap-6 text-sm font-bold text-slate-600"
      >
        {
          NAV_LINKS.map((link) => (
            <a href={link.href} class="transition-colors hover:text-emerald-700">
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>
  </div>
</header>
